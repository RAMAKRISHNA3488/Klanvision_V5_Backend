# =============================================================
# Klanvision Backend – Environment Variables
# =============================================================
# Copy this file to .env.local for local overrides (git-ignored)
# =============================================================

# --- Server ---
# Port the Express server will listen on
PORT=8080

# --- Database (MySQL) ---
DB_HOST=localhost
DB_PORT=3305
DB_NAME=klanvision_db
DB_USER=root
DB_PASS=system

# --- CORS ---
# Comma-separated list of allowed frontend origins
# Example for production: https://www.klanvision.com,https://admin.klanvision.com
CORS_ORIGIN=http://localhost:5173
