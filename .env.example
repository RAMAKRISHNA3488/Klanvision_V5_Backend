# =============================================================
# Klanvision Backend – Environment Variables Template
# =============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. Never commit .env to git (it is already in .gitignore)
# =============================================================

# --- Server ---
PORT=8080

# --- Database (MySQL) ---
DB_HOST=localhost
DB_PORT=3305
DB_NAME=klanvision_db
DB_USER=root
DB_PASS=your_mysql_password

# --- CORS ---
# Comma-separated list of allowed frontend origins
# Development:  http://localhost:5173
# Production:   https://www.klanvision.com,https://admin.klanvision.com
CORS_ORIGIN=http://localhost:5173
